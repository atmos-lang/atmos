;;;

val clear =
    S.fr_await(Debounce, _or_(:mouse.button.dn,:mouse.button.up), @1)
        ::tap \{ set txts = @{} }

val dn = 
    S.fr_await(:x.mouse.button.dn)
        ::tap \{
            set txts[+] = "dn (" ++ it.x++','++it.y ++"): " ++ it.n
        }

val up =
    S.fr_await(:x.mouse.button.up)
        ::tap \{
            set txts[+] = "up (" ++ it.x++','++it.y ++")"
        }

S.from@{clear,dn,up}::xpar()::to()
await(false)
